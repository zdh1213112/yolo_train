# Docker 基础镜像
# 网络访问 Docker Hub 不稳定时，可以改成可用镜像源
BASE_IMAGE=docker.m.daocloud.io/python:3.11-slim

# Debian 软件源
# 容器内 apt-get 很慢时，可以改成镜像站
APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian

# Python 包索引
# pip 下载慢时，可以改成镜像站
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# PyTorch 版本
# 50 系显卡优先使用官方 CUDA 12.8 wheel，兼容性更稳
TORCH_VERSION=2.10.0
TORCHVISION_VERSION=0.25.0
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu128

# YOLO 任务类型
# 这里是旋转框检测，所以用 obb
YOLO_TASK=obb

# 训练时使用的基础模型/预训练权重
# n 最小最快，显存占用也最低
# 如果这里直接写文件名，下载脚本会自动保存到 models/ 目录
# 如果你已经手动下载到项目里，推荐写成 models/yolo26n-obb.pt
YOLO_MODEL=models/yolo26n-obb.pt

# 预训练权重下载地址
# 配合 ./scripts/download_model.sh 使用
YOLO_MODEL_URL=https://ghproxy.com/https://github.com/ultralytics/assets/releases/download/v8.4.0/yolo26n-obb.pt

# 预训练权重下载镜像
# 默认已经走 ghproxy；这里只在你想临时覆盖下载地址时再设置
YOLO_MODEL_URL_MIRROR=

# 数据集配置文件路径
# 这个 yaml 里会写数据集位置、类别数、类别名
YOLO_DATA=data/dataset.yaml

# 训练输出的根目录
# 训练日志、权重文件都会放到这里
YOLO_PROJECT=outputs/train

# 这次训练任务的名字
# 最终输出目录通常会变成 outputs/train/obb_demo
YOLO_RUN_NAME=obb_demo

# 训练轮数
# 1 个 epoch = 全部训练数据完整跑一遍
YOLO_EPOCHS=100

# 训练输入图像尺寸
# 越大越容易学到小目标，但更吃显存和时间
YOLO_IMGSZ=640

# batch size
# 每次送进模型一起训练的图片数量
# 显存不够时要调小
YOLO_BATCH=8

# 数据加载线程数
# 一般 2~8 都常见，机器越强可以适当调大
YOLO_WORKERS=4

# 使用哪块设备训练
# 0 表示第一张 GPU，cpu 表示只用 CPU
YOLO_DEVICE=0

# Docker 训练时暴露给容器的 GPU
# 常见写法：all、device=0
DOCKER_GPUS=all

# Docker 训练容器共享内存大小
# 数据加载报 shm 不足时可设为 8g
DOCKER_SHM_SIZE=8g


# 导出模型格式
# onnx 兼容性最好，适合后续部署
YOLO_EXPORT_FORMAT=onnx

# 导出时使用的输入尺寸
# 一般和部署时推理尺寸保持一致
YOLO_EXPORT_IMGSZ=640

# 导出时使用的设备
# cpu 最稳，避免某些 GPU 导出兼容问题
YOLO_EXPORT_DEVICE=cpu

# 训练完成后要导出的权重路径
# 留空时优先自动选择 outputs/train 下最新一次训练的 best.pt
# 只有想强制指定某个权重文件时才填写
YOLO_WEIGHTS=


# API 服务监听地址
# 0.0.0.0 表示允许局域网或外部访问
API_HOST=0.0.0.0

# API 服务端口
# 启动后通过 http://ip:8000 访问
API_PORT=8000

# 推理时的置信度阈值
# 越高越严格，框会更少
API_CONF=0.25

# 推理时的 NMS IoU 阈值
# 控制重叠框的抑制程度
API_IOU=0.45

# API 推理时输入图像尺寸
# 建议和训练/导出尺寸接近
API_IMGSZ=1024

# Web 训练界面监听地址
# 本机使用可写 127.0.0.1，需要局域网访问可写 0.0.0.0
WEBUI_HOST=0.0.0.0

# Web 训练界面端口
WEBUI_PORT=7860
